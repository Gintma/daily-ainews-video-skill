{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "News Video Episode",
  "type": "object",
  "required": ["meta", "timing", "cover", "stories", "outro"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["title", "slug", "language", "date"],
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "language": { "type": "string" },
        "platform": { "type": "string" },
        "date": { "type": "string" },
        "topic": { "type": "string" },
        "time_window": { "type": "string" }
      }
    },
    "timing": {
      "type": "object",
      "required": ["cover_seconds", "story_seconds", "outro_seconds"],
      "properties": {
        "cover_seconds": { "type": "number", "minimum": 1 },
        "story_seconds": { "type": "number", "minimum": 3 },
        "outro_seconds": { "type": "number", "minimum": 1 },
        "scene_seconds": {
          "type": "array",
          "items": { "type": "number", "minimum": 0.5 }
        },
        "total_seconds": { "type": "number", "minimum": 1 }
      }
    },
    "cover": {
      "type": "object",
      "required": ["kicker", "title", "subtitle", "script"],
      "properties": {
        "kicker": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "script": { "type": "string" }
      }
    },
    "stories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "rank",
          "title_en",
          "title_zh",
          "source",
          "url",
          "date",
          "category",
          "metric",
          "headline_lines",
          "translation",
          "callout",
          "script"
        ],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "title_en": { "type": "string" },
          "title_zh": { "type": "string" },
          "source": { "type": "string" },
          "url": { "type": "string" },
          "date": { "type": "string" },
          "category": { "type": "string" },
          "metric": { "type": "string" },
          "headline_lines": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "items": { "type": "string" }
          },
          "translation": { "type": "string" },
          "callout": { "type": "string" },
          "script": { "type": "string" },
          "visual_prompt": { "type": "string" },
          "image_path": { "type": "string" },
          "visual_direction": {
            "type": "object",
            "required": ["layout", "image_strategy", "composition", "motion"],
            "properties": {
              "layout": {
                "type": "string",
                "enum": ["typography-led", "image-led", "diagram-led", "split-panel", "poster"]
              },
              "image_strategy": {
                "type": "string",
                "enum": ["generate", "none"]
              },
              "composition": { "type": "string" },
              "shapes": {
                "type": "array",
                "items": { "type": "string" }
              },
              "image_prompt": { "type": "string" },
              "motion": { "type": "string" }
            }
          },
          "confidence": { "type": "string" }
        }
      }
    },
    "outro": {
      "type": "object",
      "required": ["title", "subtitle", "script"],
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "script": { "type": "string" }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "url"],
        "properties": {
          "title": { "type": "string" },
          "url": { "type": "string" },
          "publisher": { "type": "string" },
          "date": { "type": "string" }
        }
      }
    }
  }
}
